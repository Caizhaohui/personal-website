---
/**
 * Card for a portfolio project entry.
 */
import type { CollectionEntry } from 'astro:content';
import { t, defaultLang, type UIKey } from '../i18n/ui';
import { base } from '../utils/base';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { name, description, techStack, repo, demo, status } = project.data;
const href = `${base}/projects/${project.slug}/`;

const STATUS_KEYS: Record<typeof status, UIKey> = {
  active: 'projects.status.active',
  maintenance: 'projects.status.maintenance',
  archived: 'projects.status.archived',
};
const statusLabel = t(STATUS_KEYS[status], defaultLang);
---

<article class="project-card">
  <div class="project-card__head">
    <h3 class="project-card__name">
      <a href={href}>{name}</a>
    </h3>
    <span class={`status status--${status}`}>{statusLabel}</span>
  </div>
  <p class="project-card__desc">{description}</p>
  {
    techStack.length > 0 && (
      <ul class="tech-list" list-style="none">
        {techStack.map((tech) => (
          <li>{tech}</li>
        ))}
      </ul>
    )
  }
  <div class="project-card__links">
    <a href={href}>详情 →</a>
    {repo && <a href={repo} target="_blank" rel="noopener noreferrer">{t('projects.viewRepo', defaultLang)}</a>}
    {demo && <a href={demo} target="_blank" rel="noopener noreferrer">{t('projects.viewDemo', defaultLang)}</a>}
  </div>
</article>

<style>
  .project-card {
    padding: var(--space-6);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: var(--transition-colors), box-shadow 0.15s ease;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .project-card:hover {
    box-shadow: var(--shadow);
    border-color: var(--color-text-subtle);
  }

  .project-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }

  .project-card__name {
    font-size: 1.15rem;
    font-weight: 650;
    margin: 0;
  }

  .project-card__name a {
    color: var(--color-text);
  }

  .project-card__name a:hover {
    color: var(--color-link);
    text-decoration: none;
  }

  .status {
    font-size: 0.75rem;
    padding: 0.1em 0.5em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .status--active {
    color: #1a7f37;
    background-color: rgba(26, 127, 55, 0.12);
  }
  .status--maintenance {
    color: #9a6700;
    background-color: rgba(154, 103, 0, 0.15);
  }
  .status--archived {
    color: var(--color-text-subtle);
    background-color: var(--color-bg-muted);
  }

  :global([data-theme='dark']) .status--active {
    color: #3fb950;
  }
  :global([data-theme='dark']) .status--maintenance {
    color: #d29922;
  }

  .project-card__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .tech-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }

  .tech-list li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.1em 0.5em;
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
  }

  .project-card__links {
    display: flex;
    gap: var(--space-4);
    font-size: 0.9rem;
    margin-top: var(--space-1);
  }
</style>
