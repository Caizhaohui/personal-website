---
/**
 * Compact list-row card for a blog post (homepage + posts index).
 * Minimal: title, date, description, tags. No cover image (intentional).
 */
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { withBase } from '../utils/base';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = withBase(`/posts/${post.slug}/`);
---

<article class="post-card">
  <h3 class="post-card__title">
    <a href={href}>{title}</a>
  </h3>
  <div class="post-card__meta">
    <FormattedDate date={pubDate} />
  </div>
  {description && <p class="post-card__desc">{description}</p>}
  {tags.length > 0 && <TagList tags={tags} />}
</article>

<style>
  .post-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card__title {
    font-size: 1.25rem;
    font-weight: 650;
    margin: 0 0 var(--space-1);
    line-height: 1.35;
  }

  .post-card__title a {
    color: var(--color-text);
  }

  .post-card__title a:hover {
    color: var(--color-link);
    text-decoration: none;
  }

  .post-card__meta {
    font-size: 0.85rem;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-2);
  }

  .post-card__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-2);
    line-height: 1.6;
  }
</style>
