---
/**
 * Top navigation bar. Minimal: site title + a few links + theme toggle.
 * No sidebar, no mega-menu.
 */
import { SITE_TITLE } from '../consts';
import { t, defaultLang } from '../i18n/ui';
import { withBase, base } from '../utils/base';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: t('nav.home', defaultLang) },
  { href: '/posts/', label: t('nav.posts', defaultLang) },
  { href: '/projects/', label: t('nav.projects', defaultLang) },
  { href: '/tags/', label: t('nav.tags', defaultLang) },
  { href: '/about/', label: t('nav.about', defaultLang) },
] as const;

const path = Astro.url.pathname;
// Normalize for matching: strip the configured base so `/repo/posts/` → `/posts/`.
const normalizedPath = (base !== '/' && path.startsWith(base) ? path.slice(base.length - 1) : path) || '/';
const isActive = (href: string) => {
  if (href === '/') return normalizedPath === '/' || normalizedPath === '';
  return normalizedPath === href || normalizedPath.startsWith(`${href}`);
};
---

<header class="site-header">
  <div class="container container--wide header-inner">
    <a href={base} class="site-title">{SITE_TITLE}</a>
    <nav class="site-nav" aria-label="主导航">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    height: 56px;
  }

  .site-title {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .site-title:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  .site-nav {
    margin-left: auto;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: var(--space-4);
    padding: 0;
    margin: 0;
  }

  .site-nav a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
    transition: var(--transition-colors);
  }

  .site-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-nav a[aria-current='page'] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 560px) {
    .site-nav ul {
      gap: var(--space-3);
    }
    .site-nav a {
      font-size: 0.85rem;
    }
    .header-inner {
      gap: var(--space-2);
    }
  }
</style>
