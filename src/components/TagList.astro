---
/**
 * Inline list of tag chips. Links to /tags/<tag>/.
 */
import { base } from '../utils/base';

interface Props {
  tags: string[];
  /** Render as inline (paragraphs) or block. */
  class?: string;
}

const { tags, class: className = '' } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class={`tag-list ${className}`} list-style="none">
      {tags.map((tag) => (
        <li>
          <a href={`${base}/tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }

  .tag-list a {
    display: inline-block;
    padding: 0.15em 0.6em;
    font-size: 0.8rem;
    color: var(--color-tag-text);
    background-color: var(--color-tag-bg);
    border-radius: var(--radius-sm);
    transition: var(--transition-colors);
  }

  .tag-list a:hover {
    color: var(--color-link);
    text-decoration: none;
    background-color: var(--color-bg-muted);
  }
</style>
