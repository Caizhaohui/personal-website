---
/**
 * Layout for a single project page.
 */
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { t, defaultLang } from '../i18n/ui';
import { base } from '../utils/base';
import '../styles/prose.css';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { name, description, techStack, repo, demo, status } = project.data;
const STATUS_KEYS = {
  active: 'projects.status.active',
  maintenance: 'projects.status.maintenance',
  archived: 'projects.status.archived',
} as const;
const statusLabel = t(STATUS_KEYS[status], defaultLang);
const backHref = `${base}/projects/`;
---

<BaseLayout title={name} description={description}>
  <article class="project">
    <a href={backHref} class="back-link">← {t('nav.projects', defaultLang)}</a>
    <header class="project__header">
      <div class="project__title-row">
        <h1 class="project__title">{name}</h1>
        <span class={`status status--${status}`}>{statusLabel}</span>
      </div>
      <p class="project__desc">{description}</p>
      {
        techStack.length > 0 && (
          <ul class="tech-list" list-style="none">
            {techStack.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        )
      }
      <div class="project__links">
        {repo && <a href={repo} target="_blank" rel="noopener noreferrer">↗ {t('projects.viewRepo', defaultLang)}</a>}
        {demo && <a href={demo} target="_blank" rel="noopener noreferrer">↗ {t('projects.viewDemo', defaultLang)}</a>}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project {
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-6);
  }

  .project__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .project__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .project__title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    margin: 0;
  }

  .status {
    font-size: 0.8rem;
    padding: 0.15em 0.6em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .status--active {
    color: #1a7f37;
    background-color: rgba(26, 127, 55, 0.12);
  }
  .status--maintenance {
    color: #9a6700;
    background-color: rgba(154, 103, 0, 0.15);
  }
  .status--archived {
    color: var(--color-text-subtle);
    background-color: var(--color-bg-muted);
  }

  :global([data-theme='dark']) .status--active {
    color: #3fb950;
  }
  :global([data-theme='dark']) .status--maintenance {
    color: #d29922;
  }

  .project__desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .tech-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    margin: var(--space-3) 0;
  }

  .tech-list li {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.15em 0.55em;
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
  }

  .project__links {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-4);
    font-size: 0.95rem;
  }
</style>
